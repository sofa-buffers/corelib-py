{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits"
  ],
  "timezone": "Europe/Berlin",
  "schedule": ["before 6am on monday"],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "Group all GitHub Actions bumps into one PR.",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions"
    },
    {
      "description": "Python build/dev dependencies from pyproject.toml (hatchling build backend); the runtime package has no dependencies.",
      "matchManagers": ["pep621"],
      "groupName": "python dependencies"
    },
    {
      "description": "Devcontainer base image (.devcontainer/Dockerfile -> ubuntu).",
      "matchManagers": ["dockerfile"],
      "groupName": "devcontainer image"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track the pinned Python minor (ARG PYTHON_VERSION) in the devcontainer Dockerfile.",
      "managerFilePatterns": ["/(^|/)\\.devcontainer/Dockerfile$/"],
      "matchStrings": ["ARG PYTHON_VERSION=(?<currentValue>\\S+)"],
      "depNameTemplate": "python",
      "datasourceTemplate": "python-version"
    }
  ]
}
