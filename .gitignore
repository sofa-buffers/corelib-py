# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# native accelerator build artifacts (Cython-generated C + compiled extension);
# regenerated from src/sofab/_speedups.pyx by the build (Cython is a build-time
# dependency declared in pyproject.toml).
src/sofab/_speedups.c
*.so

# virtualenvs
.venv/
venv/

# secrets / local env (never commit credentials)
.env
*.env

# tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Sphinx docs: build output and auto-generated apidoc stubs (regenerated by
# the docs.yml workflow via `sphinx-apidoc -f`). Only conf.py / index.rst are
# tracked.
docs/_build/
docs/modules.rst
docs/sofab*.rst
/site/
